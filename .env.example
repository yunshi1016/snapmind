# ===== SnapMind AI 配置样例 =====
# 说明：客户端本体的 AI 配置在「应用内设置页」填写，API Key 走系统安全存储（不读 .env）。
# 这个文件主要供「开发 / 集成测试脚本」使用。复制为 .env 后填入真实值（.env 已被 .gitignore 忽略）。

# --- AI 服务（OpenAI 兼容接口）---
# 默认 MiniMax 多模态。换 provider 只需改这三个值。
#   MiniMax 国际站:  https://api.minimax.io/v1
#   MiniMax 国内站:  https://api.minimaxi.com/v1   (注意是 minimaxi，多一个 i；以官方控制台为准)
#   OpenAI:         https://api.openai.com/v1
#   DeepSeek:       https://api.deepseek.com/v1
#   通义(DashScope兼容): https://dashscope.aliyuncs.com/compatible-mode/v1
#   本地 Ollama:     http://localhost:11434/v1
AI_BASE_URL=https://api.minimax.io/v1

AI_API_KEY=sk-your-key-here

# 必须是「多模态 / 能读图」的模型。MiniMax 请用 M3 / VL 系列；切勿用纯文本款（如 M2.7）。
# 具体可用模型 id 以你账号的控制台为准。
AI_MODEL=MiniMax-M3

# 可选：请求超时（毫秒）
AI_TIMEOUT_MS=60000
